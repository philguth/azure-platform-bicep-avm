using './main.bicep'

// Copy this file to dev.local.bicepparam and customize.
// The *.local.bicepparam pattern is gitignored.

param location = 'eastus'
param namePrefix = 'philguth-dev'
param tags = {
  Project: 'AzurePlatformLearning'
  Env: 'dev'
  Owner: 'Philip'
}

// Option A (portable across subscriptions):
// Keep this aligned with the bootstrap output for the same environment.
param keyVaultName = 'philguth-dev-kv-3ulptvvptoz46'
param keyVaultResourceGroupName = 'rg-philguth-bootstrap-dev'

// Option B (explicit):
// param keyVaultResourceId = '/subscriptions/<subId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<name>'
